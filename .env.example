# Copy this file to .env and adjust values before running.
# Never commit .env to version control.

# --- Postgres ---
POSTGRES_USER=tracelens
POSTGRES_PASSWORD=tracelens
POSTGRES_DB=tracelens
# Use "localhost" when running backend outside Docker
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Derived connection URL — you can set this directly instead of the vars above.
# DATABASE_URL=postgresql+psycopg2://tracelens:tracelens@db:5432/tracelens

# --- Backend ---
BACKEND_PORT=8000
BACKEND_HOST=0.0.0.0

# "development" | "production"
ENVIRONMENT=development

# Comma-separated list of allowed CORS origins.
# Use * only for local dev.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Frontend ---
FRONTEND_PORT=3000

# URL the browser uses to reach the FastAPI backend.
# Keep as localhost:8000 — this is resolved by the browser, not Docker.
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- LLM / Evaluation judge ---
# Leave OPENAI_API_KEY empty to use only the heuristic judge (no cost, no key).
# Set it to enable the LLM judge when judge="llm" or TRACELENS_EVAL_JUDGE=llm.
OPENAI_API_KEY=

# Default judge used when POST /v1/traces/{id}/rag omits the `judge` field.
#   heuristic  — deterministic word-overlap scoring, no API calls (default)
#   llm        — OpenAI-backed scoring with automatic heuristic fallback
TRACELENS_EVAL_JUDGE=heuristic

# OpenAI model used by the LLM judge. gpt-4.1-mini offers a good cost/quality
# balance; swap for gpt-4o or gpt-4.1 for higher accuracy.
TRACELENS_LLM_JUDGE_MODEL=gpt-4.1-mini

# HTTP timeout in seconds for OpenAI requests. Exceeded requests fall back to
# the heuristic judge automatically.
TRACELENS_LLM_JUDGE_TIMEOUT_SECONDS=20

# Copy this file to .env and adjust values before running.
# Never commit .env to version control.

# --- Postgres ---
POSTGRES_USER=tracelens
POSTGRES_PASSWORD=tracelens
POSTGRES_DB=tracelens
# Use "localhost" when running backend outside Docker
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Derived connection URL — you can set this directly instead of the vars above.
# DATABASE_URL=postgresql+psycopg2://tracelens:tracelens@db:5432/tracelens

# --- Backend ---
BACKEND_PORT=8000
BACKEND_HOST=0.0.0.0

# "development" | "production"
ENVIRONMENT=development

# Comma-separated list of allowed CORS origins.
# Use * only for local dev.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000
